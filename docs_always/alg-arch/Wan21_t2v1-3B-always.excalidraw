      "text": "sinusoid = torch.outer(\n        position, torch.pow(10000, -\ntorch.arange(half).to(position).div(half)))\n    x = torch.cat([torch.cos(sinusoid),\ntorch.sin(sinusoid)], dim=1)",
      "fontSize": 16,
      "fontFamily": 5,
